# Run Minecraft server
docker run -it \
	   --name mc-temp \
	   -p 25565:25565 \
	   -e EULA=TRUE \
	   -e TYPE=PAPER \
	   -v $(pwd)/plugins:/data/plugins \
	   -v $(pwd)/world:/data/world \
	   itzg/minecraft-server

# Debug requests using reverse proxy
  mitmproxy:
    image: mitmproxy/mitmproxy
    command: mitmweb --mode reverse:http://web:3000 --listen-port 8080 --web-host 0.0.0.0 --set web_password=admin
    ports:
      - "8080:8080"
      - "8081:8081"

# Reclaim system space
sudo du -h --max-depth=1 / | grep -E '^[0-9\.]+G'
docker system prune
sudo paccache -rk1
rm -rf ~/.cache
rm -rf ~/.local/share/Trash

